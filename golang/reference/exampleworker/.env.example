# exampleworker configuration. Copy to .env for local use; NEVER commit a real
# .env with secrets. Every key here is also documented in the README. Precedence
# is flags > environment > these defaults.

# --- Probe / metrics sidecar (HTTP) ---
# Listen address for /livez, /readyz, /metrics. The worker is not an HTTP
# service; this listener carries only probes and the scrape endpoint.
HTTP_ADDR=:8080
# Bound reading request headers (server hardening).
HTTP_READ_HEADER_TIMEOUT=5s
# Bound reading the full request including body.
HTTP_READ_TIMEOUT=15s
# Bound writing the response.
HTTP_WRITE_TIMEOUT=15s
# Bound idle keep-alive connection lifetime.
HTTP_IDLE_TIMEOUT=60s

# --- Broker / topic ---
# Logical topic/subject the consumer subscribes to and the outbox relay
# publishes to. Broker selection is an ADR decision; the reference build uses an
# in-memory broker, so this is just a logical name.
TOPIC=widget.events

# --- Consumer retry policy ---
# Total delivery attempts (including the first) before dead-lettering.
CONSUMER_MAX_ATTEMPTS=5
# Base retry backoff; the exponential ceiling doubles each attempt, then full
# jitter is applied (a uniform draw in [0, ceiling]) from the injected clock.
CONSUMER_BASE_BACKOFF=100ms
# Cap on the exponential backoff ceiling.
CONSUMER_MAX_BACKOFF=30s

# --- Outbox relay ---
# How often the transactional-outbox relay scans for pending rows to publish.
OUTBOX_POLL_INTERVAL=1s
# Max pending rows the relay claims per scan.
OUTBOX_BATCH_SIZE=100

# --- Telemetry ---
# Log level: debug | info | warn | error.
LOG_LEVEL=info
# Emit JSON logs (true for production, false for local text).
LOG_JSON=true
# OTLP/HTTP trace collector endpoint as host:port (NO scheme), e.g.
# otel-collector:4318. Empty disables span export: the worker installs a
# never-sampling tracer provider and runs fully offline.
OTLP_ENDPOINT=
# Send spans over plaintext HTTP instead of TLS. Only for in-cluster collectors
# or local development.
OTLP_INSECURE=false
# Head-based trace sampling ratio in [0,1]. 1.0 samples every trace; 0.0 none.
# Ignored when OTLP_ENDPOINT is empty. The Prometheus scrape endpoint at
# GET /metrics needs no configuration; it is always exposed.
TRACE_SAMPLE_RATIO=1.0

# --- Lifecycle ---
# Graceful drain budget. Must exceed worst-case in-flight message processing and
# stay under the platform termination grace (e.g. Kubernetes
# terminationGracePeriodSeconds).
SHUTDOWN_GRACE=15s
