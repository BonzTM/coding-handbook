# Build output and binaries
/bin
/out
/dist
*.exe
# The built binary at the module root only: a bare "examplegrpc" pattern
# would also ignore the cmd/examplegrpc source directory.
/examplegrpc

# Local tool binaries (buf codegen plugins installed by `make tools`)
.tools

# Test and coverage artifacts
*.test
cover.out
coverage.out
coverage.html
*.prof

# Local environment and secrets
.env
.env.*
!.env.example
*.local

# Editor/IDE cruft
.idea
.vscode
*.swp
.DS_Store
