# examplegrpc configuration. Precedence: flags > environment > defaults.
# Every key here maps to a config.Load flag and is validated fail-fast at startup.

# --- gRPC server ---
GRPC_ADDR=:9090
GRPC_MAX_RECV_MSG_BYTES=4194304      # 4 MiB
GRPC_HANDLER_TIMEOUT=15s             # server-side ceiling when a client sends no deadline
GRPC_CONN_TIMEOUT=10s

# --- metrics/probes HTTP sidecar (gRPC has no metrics endpoint) ---
HTTP_ADDR=:8080
HTTP_READ_HEADER_TIMEOUT=5s

# --- telemetry ---
LOG_LEVEL=info                       # debug|info|warn|error
LOG_JSON=true                        # false for human-readable text in local dev
OTLP_ENDPOINT=                       # host:port, no scheme; empty disables span export
OTLP_INSECURE=false                  # plaintext HTTP to the collector (in-cluster/dev only)
TRACE_SAMPLE_RATIO=1.0               # head-based parent sampling ratio in [0,1]

# --- auth (config-gated) ---
AUTH_ENABLED=false                   # true requires a valid bearer token on every RPC
AUTH_TOKEN=                          # required when AUTH_ENABLED=true

# --- lifecycle ---
SHUTDOWN_GRACE=15s
