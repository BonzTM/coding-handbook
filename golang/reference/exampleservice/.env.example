# exampleservice configuration. Copy to .env for local use; NEVER commit a real
# .env with secrets. Every key here is also documented in the README. Precedence
# is flags > environment > these defaults.

# --- HTTP server ---
# Listen address.
HTTP_ADDR=:8080
# Bound reading request headers (server hardening).
HTTP_READ_HEADER_TIMEOUT=5s
# Bound reading the full request including body.
HTTP_READ_TIMEOUT=15s
# Bound writing the response. Do not set for streaming endpoints.
HTTP_WRITE_TIMEOUT=15s
# Bound idle keep-alive connection lifetime.
HTTP_IDLE_TIMEOUT=60s
# Max non-streaming request body size in bytes (1 MiB).
HTTP_MAX_BODY_BYTES=1048576

# --- Database (database/sql pool) ---
# DSN. Empty selects the in-memory store (this reference build links no driver).
DB_DSN=
# Cap total open connections (DB capacity / number of instances).
DB_MAX_OPEN_CONNS=25
# Idle floor; must be <= DB_MAX_OPEN_CONNS.
DB_MAX_IDLE_CONNS=25
# Bound connection age (required behind a load balancer / proxy / failover).
DB_CONN_MAX_LIFETIME=30m
# Reap idle connections so the pool shrinks under low load.
DB_CONN_MAX_IDLE_TIME=5m

# --- Telemetry ---
# Log level: debug | info | warn | error.
LOG_LEVEL=info
# Emit JSON logs (true for production, false for local text).
LOG_JSON=true

# --- Lifecycle ---
# Graceful shutdown budget. Must exceed worst-case in-flight work and stay under
# the platform termination grace (e.g. Kubernetes terminationGracePeriodSeconds).
SHUTDOWN_GRACE=15s
