# exampleservice configuration. Copy to .env for local use; NEVER commit a real
# .env with secrets. Every key here is also documented in the README. Precedence
# is flags > environment > these defaults.

# --- HTTP server ---
# Listen address.
HTTP_ADDR=:8080
# Bound reading request headers (server hardening).
HTTP_READ_HEADER_TIMEOUT=5s
# Bound reading the full request including body.
HTTP_READ_TIMEOUT=15s
# Bound writing the response. Do not set for streaming endpoints.
HTTP_WRITE_TIMEOUT=15s
# Bound idle keep-alive connection lifetime.
HTTP_IDLE_TIMEOUT=60s
# Max non-streaming request body size in bytes (1 MiB).
HTTP_MAX_BODY_BYTES=1048576

# --- Database (database/sql pool) ---
# DSN. Empty selects the in-memory store (offline default). When set, the build
# uses the Postgres store over database/sql with the pure-Go pgx driver linked in
# (CGO_ENABLED=0 stays true). Example:
#   postgres://user:pass@localhost:5432/exampleservice?sslmode=disable
DB_DSN=
# Cap total open connections (DB capacity / number of instances).
DB_MAX_OPEN_CONNS=25
# Idle floor; must be <= DB_MAX_OPEN_CONNS.
DB_MAX_IDLE_CONNS=25
# Bound connection age (required behind a load balancer / proxy / failover).
DB_CONN_MAX_LIFETIME=30m
# Reap idle connections so the pool shrinks under low load.
DB_CONN_MAX_IDLE_TIME=5m
# Apply the embedded goose migrations on startup (DB-backed builds only; ignored
# when DB_DSN is empty). Off by default: schema changes are usually a separate,
# gated deploy step. Enable for a single-instance dev/CI build that self-migrates.
DB_MIGRATE_ON_STARTUP=false

# --- Telemetry ---
# Log level: debug | info | warn | error.
LOG_LEVEL=info
# Emit JSON logs (true for production, false for local text).
LOG_JSON=true
# OTLP/HTTP trace collector endpoint as host:port (NO scheme), e.g.
# otel-collector:4318. Empty disables span export: the service installs a
# never-sampling tracer provider and runs fully offline.
OTLP_ENDPOINT=
# Send spans over plaintext HTTP instead of TLS. Only for in-cluster collectors
# or local development.
OTLP_INSECURE=false
# Head-based trace sampling ratio in [0,1]. 1.0 samples every trace; 0.0 none.
# Ignored when OTLP_ENDPOINT is empty. The Prometheus scrape endpoint at
# GET /metrics needs no configuration; it is always exposed.
TRACE_SAMPLE_RATIO=1.0

# --- Identity / authentication (JWT + JWKS) ---
# Require a valid Bearer JWT on every API request. OFF by default: the service
# then runs in local/dev mode and treats requests as a synthetic principal
# (tenant "local-dev", reader+writer roles) so it boots offline without an IdP.
# When true, AUTH_ISSUER, AUTH_AUDIENCE, and AUTH_JWKS_URL are all required
# (fail-fast) and the token verifier validates iss/aud and the JWKS signature.
AUTH_ENABLED=false
# Expected JWT issuer (the "iss" claim / your identity provider).
AUTH_ISSUER=
# Expected JWT audience (the "aud" claim / this service's identifier).
AUTH_AUDIENCE=
# JWKS endpoint the verifier fetches signing keys from, e.g.
# https://idp.example.com/.well-known/jwks.json. Keys are cached and refreshed
# in the background; only RS*/ES* algorithms are accepted (alg=none is rejected).
AUTH_JWKS_URL=

# --- Idempotency (Idempotency-Key for unsafe writes) ---
# How long a stored Idempotency-Key response stays replayable. After it lapses
# the key may be reused and abandoned in-flight keys are reclaimed.
IDEMPOTENCY_TTL=24h

# --- Audit logging ---
# Security-relevant actions (authentication failure, authorization denial, and a
# successful data-mutating write) are emitted as structured audit events to a
# DEDICATED logger on its own stream (the reference writes them to stderr,
# separate from the app log on stdout), per operations/security.md. Audit records
# carry only who/what/when/where (actor, tenant, action, resource id, result,
# request_id) and NEVER secrets or PII payloads. There is no env knob; a
# deployment routes stderr to the org's audit sink.

# --- Lifecycle ---
# Graceful shutdown budget. Must exceed worst-case in-flight work and stay under
# the platform termination grace (e.g. Kubernetes terminationGracePeriodSeconds).
SHUTDOWN_GRACE=15s
