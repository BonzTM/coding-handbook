# Build output and binaries
/bin
/out
/dist
*.exe
# The built binary at the module root only: a bare "exampleservice" pattern
# would also ignore the cmd/exampleservice source directory.
/exampleservice

# Test and coverage artifacts
*.test
cover.out
coverage.out
coverage.html
*.prof

# Local environment and secrets
.env
.env.*
!.env.example
*.local

# Editor/IDE cruft
.idea
.vscode
*.swp
.DS_Store
