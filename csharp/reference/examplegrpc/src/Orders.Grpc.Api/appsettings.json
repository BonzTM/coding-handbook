{
  // Committed and secret-free (csharp/foundations/configuration.md): every
  // supported key appears here with a safe local default, and this file plays
  // the .env.example role. Deployments override via environment variables
  // (Section__Key), e.g. Auth__Enabled, Tls__CertPath.
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Server": {
    // gRPC listens HTTP/2-only; probes (/livez, /readyz) listen HTTP/1.1 on a
    // separate port - h2c and HTTP/1.1 cannot share a plaintext listener.
    "GrpcPort": 5001,
    "ProbesPort": 8080,
    // Server-side ceiling applied only when the client sends no deadline
    // (csharp/services/grpc-services.md).
    "MaxRpcDuration": "00:00:30",
    // Reflection is for internal services; gate it OFF at public edges.
    "EnableReflection": true
  },
  "Auth": {
    // Local/dev opt-out: calls run as a synthetic principal (tenant
    // "local-dev", reader+writer). Production MUST set Enabled=true plus a
    // bearer token via Auth__BearerToken (env/secret store, NEVER this file);
    // startup fails fast otherwise. The static token is the reference seam -
    // swap in a JWT/JWKS IAuthenticator for real identity (see README).
    "Enabled": false,
    "BearerToken": "",
    "Tenant": "tenant-a"
  },
  "Tls": {
    // All empty = plaintext local/dev listener (loud startup warning).
    // CertPath+KeyPath = TLS. +ClientCaPath = mutual TLS. A configured pair
    // that cannot load fails startup - never a silent plaintext downgrade.
    "CertPath": "",
    "KeyPath": "",
    "ClientCaPath": ""
  }
}
