{
  // Committed and secret-free (csharp/foundations/configuration.md): every
  // supported key appears here with a safe local default, and this file plays
  // the .env.example role. Deployments override via environment variables
  // (Section__Key), e.g. ConnectionStrings__Default, Auth__Enabled.
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
      // The dedicated "Orders.Audit" category is the audit stream; route it to
      // its own sink in production and never lower it below Information.
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    // Local docker-compose Postgres; in-network dev credentials, never
    // production. All four Npgsql pool limits are set deliberately
    // (csharp/services/database.md, Connection Pool Sizing).
    "Default": "Host=localhost;Port=5432;Database=orders;Username=app;Password=app;Maximum Pool Size=20;Minimum Pool Size=2;Connection Lifetime=300;Connection Idle Lifetime=60;Timeout=15"
  },
  "Auth": {
    // Local/dev opt-out: requests run as a synthetic principal (tenant
    // "local-dev", reader+writer). Production MUST set Enabled=true plus the
    // issuer Authority and this API's Audience; startup fails fast otherwise.
    "Enabled": false,
    "Authority": "",
    "Audience": ""
  },
  "Idempotency": {
    // Dedupe window for Idempotency-Key on POST /orders. A key replayed after
    // the TTL re-executes, so keep this beyond any client's retry horizon.
    "Ttl": "1.00:00:00"
  },
  "RateLimiting": {
    // Token bucket per authenticated client (falls back to client address).
    "TokenLimit": 100,
    "TokensPerPeriod": 100,
    "ReplenishmentPeriod": "00:00:01"
  },
  "Server": {
    // Default request timeout and request body cap (csharp/services/http-services.md).
    "RequestTimeout": "00:00:10",
    "MaxRequestBodyBytes": 1048576
  }
}
