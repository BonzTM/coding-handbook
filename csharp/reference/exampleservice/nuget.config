<?xml version="1.0" encoding="utf-8"?>
<!--
  nuget.config - repo-local, committed. Pins the package sources for everyone
  who clones the repo so restores do not depend on machine-level NuGet state.

  Defaults: nuget.org ONLY, with package source mapping so every package id
  must resolve from an explicitly mapped source. Mapping is the defense
  against dependency-confusion attacks - without it, an internal package name
  can be hijacked by a public package with a higher version.

  Adding an org feed:
    1. Add a second <add> under <packageSources> (keep <clear /> first).
    2. Map ONLY your org's id prefix to it, e.g.
         <packageSource key="contoso">
           <package pattern="Contoso.*" />
         </packageSource>
       and keep the nuget.org mapping as the catch-all "*".
    3. Credentials go in CI secrets / the local credential provider - never
       in this file.
-->
<configuration>

  <packageSources>
    <!-- Ignore all machine- and user-level sources; this file is the list. -->
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
  </packageSources>

  <packageSourceMapping>
    <packageSource key="nuget.org">
      <package pattern="*" />
    </packageSource>
  </packageSourceMapping>

</configuration>
