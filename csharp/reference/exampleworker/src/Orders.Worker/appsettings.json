{
  // Committed and secret-free (csharp/foundations/configuration.md): every
  // supported key appears here with a safe local default, and this file plays
  // the .env.example role. Deployments override via environment variables
  // (Section__Key), e.g. Consumer__MaxAttempts, Messaging__Topic.
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Messaging": {
    // Logical topic the consumer subscribes to and the outbox relay publishes
    // to. Broker selection is an ADR decision; the in-memory broker treats
    // this as a queue name (csharp/services/eventing-and-messaging.md).
    "Topic": "orders.events",
    // Per-topic buffer of the in-memory broker. Bounded on purpose:
    // publishers wait when it is full instead of growing without limit.
    "ChannelCapacity": 256
  },
  "Consumer": {
    // Total delivery attempts (including the first) before dead-lettering.
    "MaxAttempts": 5,
    // First retry's backoff ceiling; doubles per attempt, capped at
    // MaxBackoff, with full jitter applied on top.
    "BaseBackoff": "00:00:00.100",
    "MaxBackoff": "00:00:30"
  },
  "Outbox": {
    // Relay scan cadence; also the budget for the final flush on shutdown.
    "PollInterval": "00:00:01",
    // Max pending records claimed per scan.
    "BatchSize": 100
  }
}
